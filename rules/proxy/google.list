# Google / YouTube proxy rules: upstream first, local fallback second.
INCLUDE,upstream/blackmatrix7/google_fcm.list
INCLUDE,upstream/blackmatrix7/youtube.list
DOMAIN-KEYWORD,google
DOMAIN-KEYWORD,googleapis
DOMAIN-KEYWORD,googlevideo
DOMAIN-KEYWORD,gstatic
DOMAIN-KEYWORD,youtube
DOMAIN-SUFFIX,google.com
DOMAIN-SUFFIX,youtu.be
DOMAIN-SUFFIX,youtube.com
